<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <!--  ===== PERMISSIONS =====  -->
    <!--  Internet untuk kirim koordinat ke server  -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!--  Lokasi  -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!--  WAJIB minta runtime SECARA TERPISAH setelah FINE_LOCATION (Android 10+)  -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
    <!--  Foreground service untuk pelacakan saat app ditutup  -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!--  Notifikasi (Android 13+)  -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!--  Kamera untuk SCAN QR  -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!--  Boot complete: opsional, kalau service mau auto-start saat HP nyala  -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!--  Hardware feature  -->
    <uses-feature android:name="android.hardware.location.gps" android:required="true"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <application android:allowBackup="false" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:label="@string/app_name" android:theme="@style/Theme.Supir" android:supportsRtl="true" tools:targetApi="34">
        <!--  ===== Launcher: Login =====  -->
        <activity android:name=".LoginActivity" android:exported="true" android:screenOrientation="portrait" android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!--  ===== Dashboard =====  -->
        <activity android:name=".DashboardActivity" android:exported="false" android:screenOrientation="portrait" android:launchMode="singleTop"/>
        <!--  ===== FOREGROUND SERVICE (Persistent Notification) =====  -->
        <service android:name=".LocationForegroundService" android:exported="false" android:foregroundServiceType="location"/>
        <!--  Google Maps API key (kalau pakai Google Maps)  -->
        <meta-data android:name="com.google.android.geo.API_KEY" android:value="${MAPS_API_KEY}"/>
    </application>
</manifest>