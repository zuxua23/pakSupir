<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme (Material 3) -->
    <style name="Theme.Supir" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorError">@color/danger</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ====== TYPOGRAPHY ====== -->
    <style name="Text.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="Text.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/ink</item>
    </style>

    <style name="Text.Speed">
        <item name="android:textSize">@dimen/text_speed</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">-0.04</item>
    </style>

    <!-- ====== BUTTONS ====== -->
    <!-- Tombol utama besar (MASUK, SCAN QR) -->
    <style name="Btn.Primary.Large" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/touch_large</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="Btn.Outlined.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/touch_default</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/danger</item>
        <item name="strokeWidth">@dimen/stroke_thick</item>
        <item name="android:textColor">@color/danger</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>

    <!-- ====== INPUT ====== -->
    <style name="Input.Large" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">@dimen/stroke_thick</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="android:textSize">@dimen/text_input</item>
    </style>
</resources>
