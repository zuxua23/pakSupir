<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    Halaman login — input besar, tombol MASUK full-width 72dp.
    Catatan: FLAG_SECURE diset di LoginActivity.kt (lihat onCreate).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".LoginActivity">

    <!-- ================ HEADER BIRU ================ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="@dimen/space_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_md">

            <!-- Logo box -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_logo_box">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="SP"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/space_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/on_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Versi 1.0"
                    android:textColor="@color/on_primary"
                    android:alpha="0.8"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_subtitle"
            android:textColor="@color/on_primary"
            android:alpha="0.9"
            android:textSize="@dimen/text_body"
            android:layout_marginTop="@dimen/space_xs"/>
    </LinearLayout>

    <!-- ================ FORM ================ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <!-- ===== Nomor HP ===== -->
            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_phone"
                android:layout_marginBottom="@dimen/space_sm"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Input.Large"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_default"
                    android:hint="@string/hint_phone"
                    android:inputType="phone"
                    android:textColor="@color/ink"
                    android:textSize="@dimen/text_input"
                    android:textStyle="bold"
                    android:maxLines="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ===== PIN 6 digit ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="@dimen/space_sm">

                <TextView
                    android:id="@+id/lblPin"
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="@string/label_pin"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTogglePin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/action_show"
                    android:textColor="@color/primary"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_eye"
                    app:iconTint="@color/primary"/>
            </RelativeLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Input.Large"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPin"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_default"
                    android:hint="••••••"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:letterSpacing="0.5"
                    android:gravity="center"
                    android:textColor="@color/ink"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ===== TOMBOL MASUK ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/Btn.Primary.Large"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_large"
                android:text="@string/btn_login"
                android:layout_marginTop="@dimen/space_lg"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="end"
                app:iconTint="@color/on_primary"/>

            <!-- ===== LINKS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnForgotPin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/link_forgot_pin"
                    android:textColor="@color/primary"
                    android:textAllCaps="false"
                    android:textStyle="bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHelp"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/link_help"
                    android:textColor="@color/primary"
                    android:textAllCaps="false"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
